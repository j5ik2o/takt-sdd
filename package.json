{
  "name": "takt-sdd",
  "version": "1.0.0",
  "private": true,
  "description": "Kiro-compatible TAKT workflow surface for SDD; OpenSpec opsx workflows remain separate entrypoints",
  "devDependencies": {
    "@fission-ai/openspec": "1.3.1",
    "takt": "^0.43.0"
  },
  "scripts": {
    "cc-sdd:full": "scripts/takt.sh --pipeline --skip-git -w cc-sdd-full -t",
    "cc-sdd:requirements": "scripts/takt.sh --pipeline --skip-git -w cc-sdd-requirements -t",
    "cc-sdd:validate-gap": "scripts/takt.sh --pipeline --skip-git -w cc-sdd-validate-gap -t",
    "cc-sdd:design": "scripts/takt.sh --pipeline --skip-git -w cc-sdd-design -t",
    "cc-sdd:validate-design": "scripts/takt.sh --pipeline --skip-git -w cc-sdd-validate-design -t",
    "cc-sdd:tasks": "scripts/takt.sh --pipeline --skip-git -w cc-sdd-tasks -t",
    "cc-sdd:impl": "scripts/takt.sh --pipeline --skip-git -w cc-sdd-impl -t",
    "cc-sdd:validate-impl": "scripts/takt.sh --pipeline --skip-git -w cc-sdd-validate-impl -t",
    "cc-sdd:steering": "scripts/takt.sh --pipeline --skip-git -w cc-sdd-steering -t",
    "cc-sdd:steering-custom": "scripts/takt.sh --pipeline --skip-git -w cc-sdd-steering-custom -t",
    "opsx:full": "scripts/takt.sh --pipeline --skip-git -w opsx-full -t",
    "opsx:propose": "scripts/takt.sh --pipeline --skip-git -w opsx-propose -t",
    "opsx:apply": "scripts/takt.sh --pipeline --skip-git -w opsx-apply -t",
    "opsx:archive": "scripts/takt.sh --pipeline --skip-git -w opsx-archive -t",
    "opsx:explore": "scripts/takt.sh --skip-git -w opsx-explore"
  }
}
